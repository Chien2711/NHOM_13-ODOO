# ==========================================
# ODOO & PYTHON SPECIFIC
# ==========================================
# Loại bỏ các file Python đã biên dịch (không cần thiết trên Git)
*.py[co]
__pycache__/
*.so
*.egg-info
dist/
build/

# Loại bỏ kho lưu trữ dữ liệu của Odoo (Filestore)
# Rất quan trọng: Không đẩy ảnh/file upload của local lên Git
odoo/filestore/
odoo/sessions/
*.log

# Cấu hình server (Chứa mật khẩu DB, thông số port - Tuyệt đối không share)
odoo.conf
*.conf

# ==========================================
# IDE & EDITORS (VS Code, PyCharm, v.v.)
# ==========================================
.vscode/
.idea/
*.swp
*~
.history/

# ==========================================
# VIRTUAL ENVIRONMENTS & TOOLS
# ==========================================
venv/
.venv/
env/
bin/
lib/
share/
include/
node_modules/
package-lock.json

# ==========================================
# SYSTEM & TEMP FILES
# ==========================================
# File rác của MacOS và Linux
.DS_Store
.directory
.Trash-*
*.tmp
*.temp

# ==========================================
# DATA & EXPORTS (Tránh đẩy dữ liệu test bừa bãi)
# ==========================================
*.csv
*.xlsx
*.sql
!security/ir.model.access.csv  # Ngoại lệ: Giữ lại file phân quyền của bạn